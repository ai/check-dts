{
  "name": "check-dts",
  "version": "0.9.0",
  "description": "Unit tests for .d.ts TypeScript definitions",
  "keywords": [
    "typescript",
    "types",
    "test",
    "check"
  ],
  "bin": "./bin.js",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "funding": [
    {
      "type": "github",
      "url": "https://github.com/sponsors/ai"
    }
  ],
  "scripts": {
    "test": "vitest run --coverage && eslint ."
  },
  "author": "Andrey Sitnik <andrey@sitnik.es>",
  "license": "MIT",
  "repository": "ai/check-dts",
  "peerDependencies": {
    "typescript": ">=4.0.0"
  },
  "dependencies": {
    "fast-glob": "^3.3.3",
    "nanospinner": "^1.2.2",
    "picocolors": "^1.1.1",
    "vfile-location": "^5.0.3"
  },
  "devDependencies": {
    "@logux/eslint-config": "^57.1.0",
    "@vitest/coverage-v8": "^4.1.1",
    "actions-up": "^1.12.0",
    "clean-publish": "^6.0.4",
    "eslint": "^10.1.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.1"
  },
  "prettier": {
    "arrowParens": "avoid",
    "jsxSingleQuote": false,
    "quoteProps": "consistent",
    "semi": false,
    "singleQuote": true,
    "trailingComma": "none"
  },
  "clean-publish": {
    "cleanDocs": true
  }
}
